# Visual Studio / .NET ignore file

# User-specific files
*.rsuser
*.user
*.userosscache
*.suo
*.sln.docstates
*.sln.ide
*.userprefs

# Build results
[Bb]in/
[Oo]bj/
out/

# VS Code
.vscode/

# Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.
.vs/
TestResults/

# NuGet
*.nupkg
packages/
.nuget/
project.lock.json
project.fragment.lock.json

# Microsoft Azure Web App publish settings
*.Publish.xml
*.azurePubxml

# Publish artifacts
*.publish/
PublishProfiles/

# IIS Express
iisexpress/

# Rider
.idea/
*.sln.iml

# ReSharper
_ReSharper*/
*._ReSharper*/
*.DotSettings.user

# Coverage & profiling
*.coverage
*.coveragexml
*.profiler
*.psess
*.vsp

# NCrunch
*.ncrunch*

# Logs
*.log

# Runtime files
*.pid
*.seed

# Database files
*.mdf
*.ldf
*.sqlite
*.db

# ASP.NET Core
appsettings.Local.json
appsettings.*.Local.json
secrets.json

# Static web assets (Blazor) - avoid tracking build outputs
wwwroot/_framework/
wwwroot/_bin/

# Node/NPM
node_modules/
npm-debug.log*
yarn-error.log
package-lock.json
.pnpm-debug.log

# Temporary files
*.tmp
*.temp
*.~*

# OS generated files
.DS_Store
Thumbs.db
 ehthumbs.db

# JetBrains Rider cache
.idea/
*.sln.iml

# dotnet artifacts
artifacts/

# GitHub Actions test reports
*.trx

# End of file
